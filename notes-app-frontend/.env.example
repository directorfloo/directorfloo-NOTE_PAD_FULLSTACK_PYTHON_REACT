# Notes CRUD API (Django REST — already exists at /api/notes/)
VITE_API_URL=http://localhost:8000/api/notes

# ----------------------------------------------------------------------------
# 👇 YOUR BACKEND AUTH API GOES HERE
# Base URL for register / login / google endpoints.
# Your Django backend does NOT have these yet — you need to add:
#   POST  {VITE_AUTH_URL}/register/   body: { username, email, password }
#   POST  {VITE_AUTH_URL}/google/     body: { credential }   (Google ID token)
# Leave this BLANK to run fully in the frontend (no backend needed yet).
# ----------------------------------------------------------------------------
VITE_AUTH_URL=

# Google OAuth Client ID (from https://console.cloud.google.com/apis/credentials).
# Leave BLANK to hide the "Sign up with Google" button until you have one.
VITE_GOOGLE_CLIENT_ID=
